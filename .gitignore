# ══════════════════════════════════════════════════════════════
# .gitignore - Sécurité & Configuration
# ══════════════════════════════════════════════════════════════

# 🔐 VARIABLES D'ENVIRONNEMENT - NE JAMAIS COMMITER!
.env
.env.local
.env.*.local
.env.production
.env.test

# 📦 DÉPENDANCES
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# 🔨 BUILD & DIST
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache
.vuepress/dist/

# 🎨 IDE & ÉDITEURS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
.prettierignore
.prettierrc

# 📝 LOGS
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# 🧪 TESTS & COVERAGE
.nyc_output/
coverage/
.jest/
.mocha_output

# 🔒 FICHIERS SENSIBLES
*.pem
*.key
*.cert
*.crt
secrets.json
credentials.json

# 📱 FICHIERS TEMPORAIRES
*.tmp
*.bak
*.backup
*.swp
.temp/

# 🌐 SYSTÈME D'EXPLOITATION
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# 🚀 DÉPLOIEMENT
.vercel/
.netlify/
.env.production.local

# 📊 ANALYTICS & MONITORING
# Si vous avez des fichiers locaux de metrics

# 🎯 FICHIERS SPÉCIFIQUES AU PROJET
# Ajouter ici les fichiers locaux à ignorer
